# Copy this to .env and fill in your Firebase config
# Get these values from Firebase Console > Project Settings > Your apps
# Note: VITE_ prefix required for Vite to expose to client

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=ships-at-dawn
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# GitHub Actions secrets use shorter names (without VITE_ prefix):
# FIREBASE_API_KEY, FIREBASE_AUTH_DOMAIN, etc.
